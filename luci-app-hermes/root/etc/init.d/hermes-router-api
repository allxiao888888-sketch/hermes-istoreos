#!/bin/sh /etc/rc.common
# ============================================================================
# Hermes Router API — iStoreOS 开机自启服务
# ============================================================================
# 安装:  chmod +x /etc/init.d/hermes-router-api
# 启用:  /etc/init.d/hermes-router-api enable
# 启动:  /etc/init.d/hermes-router-api start
# 状态:  /etc/init.d/hermes-router-api status

START=99
STOP=10

USE_PROCD=1

NAME="hermes-router-api"
PROG="/usr/bin/python3"
SCRIPT="/usr/libexec/hermes-router-api/server.py"
PID_FILE="/var/run/${NAME}.pid"
LOG_FILE="/var/log/${NAME}.log"
PORT="${HERMES_PORT:-9120}"
HOST="${HERMES_HOST:-127.0.0.1}"

start_service() {
    # 检查 Python3 是否安装
    if [ ! -x "$PROG" ]; then
        logger -t "$NAME" "错误: python3 未安装！请执行: opkg install python3"
        return 1
    fi

    # 检查脚本是否存在
    if [ ! -f "$SCRIPT" ]; then
        logger -t "$NAME" "错误: 脚本 $SCRIPT 不存在"
        return 1
    fi

    # 创建日志目录
    mkdir -p /var/log

    procd_open_instance
    procd_set_param command "$PROG" "$SCRIPT" --port "$PORT" --host "$HOST"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn
    procd_set_param pidfile "$PID_FILE"
    procd_close_instance

    logger -t "$NAME" "Hermes Router API 启动: $HOST:$PORT"
}

stop_service() {
    logger -t "$NAME" "Hermes Router API 停止"
}

service_running() {
    # 检查端口是否在监听
    if netstat -an 2>/dev/null | grep -q ":$PORT "; then
        return 0
    fi
    return 1
}

reload_service() {
    # 重启服务（SIGHUP 不适合 Python http.server）
    stop
    sleep 1
    start
}
