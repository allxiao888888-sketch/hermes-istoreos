# Hermes Agent 路由器配置
# 所有服务都在路由器本地运行

config config 'config'
    # AI 提供商设置
    option llm_provider 'openrouter'
    option llm_model 'google/gemini-2.0-flash-lite-preview-02-05'
    option llm_api_key ''
    option llm_base_url 'https://openrouter.ai/api/v1'
    
    # 本地服务设置
    option api_key ''
    option local_port '9120'
    
    # 显示设置
    option theme 'dark'
    option refresh_interval '10'
